---
import "../styles/pages/projects.css";
import Layout from "../layouts/Layout.astro";
import PageHeading from "../components/PageHeading.astro";
import ProjectGraph from "../components/graph/ProjectGraph";
import { SITE_NAME } from "../consts";
import type { Project } from "../types";
import { useTranslations } from "../i18n/ui";
import { getCollection } from "astro:content";

const t = useTranslations(Astro.currentLocale);

const allProjects: Project[] = (await getCollection("projects")).map(
  (entry) => ({
    title: entry.data.title,
    subtitle: entry.data.subtitle,
    status: entry.data.status,
    desc: entry.data.desc,
    tech: entry.data.tech,
    tags: entry.data.tags,
    images: entry.data.images,
    current: entry.data.current,
    category: entry.data.category,
    slug: entry.id,
    href: entry.data.link,
  }),
);
---

<Layout
  title={`${SITE_NAME} | Projects`}
  description="Software projects and experiments by 7591yj."
>
  <main>
    <section>
      <PageHeading module="MODULE.001///" title="Projects" />
    </section>

    <section class="schematic">
      <ProjectGraph
        projects={allProjects}
        selectTechLabel={t("projects.selectTech")}
        techSelectedTemplate={t("projects.techSelected")}
        clearLabel={t("projects.clear")}
        client:visible
      />
    </section>
  </main>
</Layout>
