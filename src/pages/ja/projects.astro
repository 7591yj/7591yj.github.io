---
import "../../styles/pages/projects.css";
import Layout from "../../layouts/Layout.astro";
import PageHeading from "../../components/PageHeading.astro";
import ProjectGraph from "../../components/graph/ProjectGraph";
import { SITE_NAME } from "../../consts";
import type { Project } from "../../types";
import { useTranslations } from "../../i18n/ui";
import { getRelativeLocaleUrl } from "astro:i18n";

const t = useTranslations(Astro.currentLocale);
const internalBasePath = getRelativeLocaleUrl("ja", "/projects");

const mdxModules = import.meta.glob<{
  frontmatter: Record<string, any>;
  url: string;
}>("./projects/*.mdx", { eager: true });
const allProjects: Project[] = Object.values(mdxModules).map((p) => ({
  title: p.frontmatter.title,
  subtitle: p.frontmatter.subtitle,
  status: p.frontmatter.status,
  desc: p.frontmatter.desc ?? [],
  tech: p.frontmatter.tech ?? [],
  tags: p.frontmatter.tags ?? [],
  images: p.frontmatter.images,
  current: p.frontmatter.current,
  category: p.frontmatter.category,
  slug: p.url!.split("/").pop()!,
  href: p.frontmatter.link,
}));
---

<Layout
  title={`${SITE_NAME} | プロジェクト`}
  description="7591yjのソフトウェアプロジェクト"
>
  <main>
    <section>
      <PageHeading module="MODULE.001///" title="プロジェクト" />
    </section>

    <section class="schematic">
      <ProjectGraph
        projects={allProjects}
        selectTechLabel={t("projects.selectTech")}
        techSelectedTemplate={t("projects.techSelected")}
        clearLabel={t("projects.clear")}
        internalBasePath={internalBasePath}
        client:visible
      />
    </section>
  </main>
</Layout>
