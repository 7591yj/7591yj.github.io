---
interface Props {
  module: string;
  title: string;
}

const { module, title } = Astro.props;
---

<div class="heading flex items-end" data-animate>
  <div class="flex-3">
    <p
      class="text-l text-[var(--color-text-secondary)] mb-8 mx-auto"
      data-scramble
    >
      {module}
    </p>
    <h1 class="font-shippori pt-20 text-5xl font-bold tracking-tight">
      {title}
    </h1>
  </div>
  <div class="text-l">
    <slot />
  </div>
</div>

<style>
  .heading div {
    padding: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
  }

  @media (max-width: 768px) {
    .heading {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
