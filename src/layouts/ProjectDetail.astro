---
import DetailLayout from "./DetailLayout.astro";
import { SITE_NAME } from "../consts";
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../i18n/ui";
import type { ProjectStatus } from "../types";

interface Frontmatter {
  title: string;
  subtitle?: string;
  year?: number;
  status?: ProjectStatus;
  link?: string;
}

const { title, subtitle, year, status, link } =
  Astro.props.frontmatter as Frontmatter;
const headings = Astro.props.headings ?? [];
const locale = Astro.currentLocale ?? "en";
const t = useTranslations(locale);

const statusLabels: Record<Frontmatter["status"], string> = {
  released: t("status.released"),
  "in development": t("status.inDevelopment"),
  planned: t("status.planned"),
  prototype: t("status.prototype"),
  paused: t("status.paused"),
  archived: t("status.archived"),
};
---

<DetailLayout
  title={`${SITE_NAME} | ${title}`}
  module="MODULE.001///"
  headingTitle={title}
  subtitle={subtitle}
  backLinkHref={getRelativeLocaleUrl(locale, "/projects")}
  backLinkLabel={t("detail.backProjects")}
  headings={headings}
>
  <div class="meta" slot="meta">
    {
      year && (
        <>
          <span class="meta__label">{t("meta.year")}</span>
          <span class="meta__value">{year}</span>
        </>
      )
    }
    {
      status && (
        <>
          <span class="meta__label">{t("meta.status")}</span>
          <span class="meta__value">{statusLabels[status]}</span>
        </>
      )
    }
    {
      link && (
        <>
          <span class="meta__label">{t("meta.link")}</span>
          <a
            class="meta__link"
            href={link}
            target="_blank"
            rel="noopener noreferrer"
          >
            {link} &#8599;
          </a>
        </>
      )
    }
  </div>

  <slot />
</DetailLayout>
