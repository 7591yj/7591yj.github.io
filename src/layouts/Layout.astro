---
import { ViewTransitions } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { Font } from "astro:assets";
import { SITE_NAME, SITE_DESCRIPTION, SITE_OG_IMAGE, AUTHOR } from "../consts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishDate?: string;
  noindex?: boolean;
  transparentHeader?: boolean;
}

const {
  title = SITE_NAME,
  description,
  image,
  type = "website",
  publishDate,
  noindex = false,
  transparentHeader = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image ?? SITE_OG_IMAGE, Astro.site).href;
const metaDescription = description ?? SITE_DESCRIPTION;

const jsonLd =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description: metaDescription,
        url: canonicalUrl,
        datePublished: publishDate,
        author: { "@type": "Person", name: AUTHOR },
        image: ogImage,
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        url: Astro.site,
        name: SITE_NAME,
        description: SITE_DESCRIPTION,
      };
---

<Font cssVariable="--font-shippori" preload />

<html lang={Astro.currentLocale ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta name="description" content={metaDescription} />
    <meta name="author" content={AUTHOR} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {noindex && <meta name="robots" content="noindex" />}

    <ViewTransitions />
    <script is:inline>
      (function () {
        function resolveTheme() {
          var stored = localStorage.getItem("theme");
          var systemDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          return stored === "system" || !stored
            ? systemDark
              ? "dark"
              : "light"
            : stored;
        }
        document.documentElement.setAttribute("data-theme", resolveTheme());
        document.addEventListener("astro:after-swap", function () {
          document.documentElement.setAttribute("data-theme", resolveTheme());
        });
      })();
    </script>
  </head>
  <body>
    <Header transparentHeader={transparentHeader} />
    <slot />
    <Footer />
    <script>
      let scrollAnimateModule: Promise<unknown> | null = null;
      let headerScrollModule: Promise<unknown> | null = null;

      function loadPageScripts() {
        if (document.querySelector("[data-animate]")) {
          scrollAnimateModule ??= import("../scripts/scroll-animate.ts");
        }

        if (document.querySelector("[data-transparent-header]")) {
          headerScrollModule ??= import("../scripts/header-scroll.ts");
        }
      }

      loadPageScripts();
      document.addEventListener("astro:page-load", loadPageScripts);
    </script>
    <script src="../scripts/scramble-text.ts"></script>
    <script>
      import { initTheme, watchSystemPreference } from "../scripts/theme";
      watchSystemPreference();
      document.addEventListener("astro:page-load", () => {
        initTheme();
      });
    </script>
  </body>
</html>
<style>
  body {
    font-family: "PlemolJP", monospace;
  }
</style>
